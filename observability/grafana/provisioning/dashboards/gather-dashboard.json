{
  "uid": "gather-overview",
  "title": "Gather — Ingestion, Extraction & Contradictions",
  "tags": ["gather"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ingestion throughput by artifact kind (files/min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": { "defaults": { "unit": "opm" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(gather_ingest_files_total[5m])) * 60",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Per-file success rate (documents & images, 1h)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(gather_ingest_files_total{status!=\"rejected\",kind=~\"document_.*|image_.*\"}[1h])) / clamp_min(sum(increase(gather_ingest_files_total{kind=~\"document_.*|image_.*\"}[1h])), 1)",
          "legendFormat": "success"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open contradictions",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "gather_contradictions_open", "legendFormat": "open" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Extraction success rate by method (1h ratio)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (increase(gather_extraction_units_total{status=\"ok\"}[1h])) / clamp_min(sum by (method) (increase(gather_extraction_units_total[1h])), 1)",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Extraction backlog (pending documents / images)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "gather_extraction_backlog",
          "legendFormat": "{{modality}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Graph query latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.15 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gather_graph_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gather_graph_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API latency by route (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(gather_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Contradictions resolved (per hour, by resolution)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (resolution) (increase(gather_contradictions_resolved_total[1h]))",
          "legendFormat": "{{resolution}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Messages ingested by platform (per hour)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "gather-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (platform) (increase(gather_ingest_messages_total[1h]))",
          "legendFormat": "{{platform}}"
        }
      ]
    }
  ]
}
