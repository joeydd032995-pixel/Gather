# Gather — environment configuration. Copy to .env and edit.
# Every variable the stack reads is documented here; nothing else is required.

# --- Postgres -------------------------------------------------------------
POSTGRES_DB=gather
POSTGRES_USER=gather
# REQUIRED. Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=
# Host port for Postgres (loopback only).
POSTGRES_PORT=5432

# --- Daemon ---------------------------------------------------------------
# Host port for the daemon REST API (loopback only).
GATHER_PORT=7601
# Optional bearer token for /api/v1. Empty = open (loopback-only dev).
# The desktop app flow stores this in the OS keychain instead (write-up §7).
GATHER_API_TOKEN=
# Per-request upload cap in MB.
GATHER_MAX_UPLOAD_MB=256
# Log filter (tracing EnvFilter syntax).
RUST_LOG=info,sqlx=warn

# --- Extraction worker (PDF text, image OCR, atomic units) ----------------
# Run the background extraction worker.
GATHER_EXTRACTION_ENABLED=true
# Seconds between extraction passes.
GATHER_EXTRACTION_INTERVAL_SECS=30
# Max rows claimed per queue per pass (1-256).
GATHER_EXTRACTION_BATCH=8
# Tesseract CLI path (bundled in the Docker image; install locally for OCR).
GATHER_TESSERACT_PATH=tesseract

# --- Optional local LLM (Ollama) — OPT-IN, loopback only -------------------
# Empty = disabled (default). Set to http://127.0.0.1:11434 to enable
# LLM-assisted extraction and embeddings. Non-loopback URLs are refused.
GATHER_OLLAMA_URL=
GATHER_OLLAMA_MODEL=llama3.2:3b
GATHER_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Observability (only with: docker compose --profile observability up) --
GRAFANA_ADMIN_PASSWORD=admin
