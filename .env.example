# Gather — environment configuration. Copy to .env and edit.
# Every variable the stack reads is documented here; nothing else is required.

# --- Postgres -------------------------------------------------------------
POSTGRES_DB=gather
POSTGRES_USER=gather
# REQUIRED. Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=
# Host port for Postgres (loopback only).
POSTGRES_PORT=5432

# --- Daemon ---------------------------------------------------------------
# Host port for the daemon REST API (loopback only).
GATHER_PORT=7601
# Optional bearer token for /api/v1. Empty = open (loopback-only dev).
# The desktop app flow stores this in the OS keychain instead (write-up §7).
GATHER_API_TOKEN=
# Per-request upload cap in MB.
GATHER_MAX_UPLOAD_MB=256
# Log filter (tracing EnvFilter syntax).
RUST_LOG=info,sqlx=warn

# --- Observability (only with: docker compose --profile observability up) --
GRAFANA_ADMIN_PASSWORD=admin
